rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /apologies/{token} {
      allow list: if false;
      allow create: if request.auth != null && request.resource.data.creator_uid == request.auth.uid;
      allow read: if request.auth != null && resource.data.creator_uid == request.auth.uid
        || resource.data.is_paid == true && resource.data.expires_at > request.time;
      allow update, delete: if request.auth != null && resource.data.creator_uid == request.auth.uid;
    }
  }
}
